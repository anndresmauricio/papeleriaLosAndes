{
  "version": 2,
  "builds": [
    {
      "src": "firstapp/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "build",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles_build"
      }
    }
  ],
  "functions": {
    "firstapp/wsgi.py": {
      "memory": 3008,
      "maxDuration": 300
    },
    "api/*.js": {
      "memory": 3008,
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/staticfiles/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "firstapp/wsgi.py"
    }
  ]
}